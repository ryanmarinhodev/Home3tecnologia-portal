# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/home3_portal?schema=public"

# JWT
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"
JWT_EXPIRES_IN="7d"

# Google Drive API
GOOGLE_SERVICE_ACCOUNT_EMAIL="sua-conta-de-servico@seu-projeto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_DRIVE_ROOT_FOLDER_ID="id-da-pasta-raiz-do-google-drive"

# Server
PORT=3001
NODE_ENV="development"

# Frontend URLs (para CORS)
# Pode informar uma ou mais URLs separadas por virgula.
FRONTEND_URLS="http://localhost:8080,http://localhost:5173"
